# =========================================
# 🌐 App Configuration
# =========================================

# Public Supabase URL (safe to expose to frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public Supabase anon key (safe for frontend usage)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here


# =========================================
# 🔐 Server Secrets (DO NOT EXPOSE)
# =========================================

# Secret used for pending registration verification
PENDING_REGISTRATION_SECRET=your-random-secret-key

# Secret used to secure password reset verification sessions
PASSWORD_RESET_SECRET=your-password-reset-secret

# Supabase service role key (FULL ADMIN ACCESS - NEVER EXPOSE)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# =========================================
# 🤖 AI / External APIs
# =========================================

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key

# Groq API key (optional alternative to Gemini)
GROQ_API_KEY=your-groq-api-key

# SerpAPI key (for plagiarism/search features)
SERPAPI_KEY=your-serpapi-key


# =========================================
# 📧 Email Configuration
# =========================================

# Gmail address used for sending emails
GMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your real password)
GMAIL_APP_PASSWORD=your-app-password
